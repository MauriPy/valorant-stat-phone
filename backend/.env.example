# Copia a .env y rellena los valores

APP_NAME=Valorant Stat Phone
APP_URL=http://localhost:8000
SECRET_KEY=cambia-esto-por-un-secreto-largo-y-aleatorio

# sqlite para desarrollo; usa postgres en produccion
DATABASE_URL=sqlite:///./valorant_phone.db

# Proveedor de stats: "riot" o "tracker"
STATS_PROVIDER=tracker

# --- Tracker Network (https://tracker.gg/developers) ---
TRACKER_API_KEY=
TRACKER_API_BASE=https://public-api.tracker.gg

# --- Riot RSO (tras aprobacion en developer.riotgames.com) ---
RIOT_CLIENT_ID=
RIOT_CLIENT_SECRET=
RIOT_REDIRECT_URI=http://localhost:8000/auth/riot/callback
RIOT_OAUTH_AUTHORIZE_URL=https://auth.riotgames.com/authorize
RIOT_OAUTH_TOKEN_URL=https://auth.riotgames.com/token
RIOT_ACCOUNT_REGION=americas

# Token que la ESP32 envia en header X-Device-Secret (opcional en dev)
REQUIRE_DEVICE_SECRET=true

# Solo desarrollo: vincular Riot ID manual en /setup (apagar en produccion)
DEV_ALLOW_MANUAL_LINK=true
