# Copia a .env y rellena los valores

APP_NAME=Valorant Stat Phone
APP_URL=http://localhost:8000
SECRET_KEY=cambia-esto-por-un-secreto-largo-y-aleatorio

# sqlite para desarrollo local; en Railway usa Postgres (variable DATABASE_URL automatica)
DATABASE_URL=sqlite:///./valorant_phone.db

# Proveedor de stats: "henrik" (dev), "tracker" o "riot"
STATS_PROVIDER=henrik

# --- Tracker Network (https://tracker.gg/developers) — Valorant NO soportado oficialmente ---
TRACKER_API_KEY=
TRACKER_API_BASE=https://public-api.tracker.gg

# --- HenrikDev (gratis para desarrollo) https://api.henrikdev.xyz/dashboard/ ---
HENRIK_API_KEY=

# --- Riot RSO (tras aprobacion en developer.riotgames.com) ---
RIOT_CLIENT_ID=
RIOT_CLIENT_SECRET=
RIOT_REDIRECT_URI=http://localhost:8000/auth/riot/callback
RIOT_OAUTH_AUTHORIZE_URL=https://auth.riotgames.com/authorize
RIOT_OAUTH_TOKEN_URL=https://auth.riotgames.com/token
RIOT_ACCOUNT_REGION=americas

# Verificacion Riot: GET /riot.txt (opcional si existe backend/riot.txt en el deploy)
RIOT_VERIFICATION_CODE=

# Token que la ESP32 envia en header X-Device-Secret (opcional en dev)
REQUIRE_DEVICE_SECRET=true

# Solo desarrollo: vincular Riot ID manual en /setup (apagar en produccion)
DEV_ALLOW_MANUAL_LINK=true

# --- Railway (ejemplo) ---
# APP_URL=https://valorant-stat-phone-production.up.railway.app
# RIOT_REDIRECT_URI=https://valorant-stat-phone-production.up.railway.app/auth/riot/callback
# DATABASE_URL=postgresql://...  (Railway la inyecta al enlazar Postgres)
# DEV_ALLOW_MANUAL_LINK=false
